# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.venv/
venv/

# Environment
.env
.env.local

# Provider-specific CA bundles (organization-specific, do not ship)
configs/certs/

# IDE
.vscode/
.idea/
*.swp
*.swo

# Runtime storage (not tracked)
storage/qdrant/
storage/uploads/
storage/reports/
storage/eval_history/
storage/ingestion_checkpoints/

# Downloaded models (sentence-transformers cache, etc.)
models/

# Logs
*.log
logs/

# OS
.DS_Store
Thumbs.db

# Test / coverage
.coverage
htmlcov/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Visual regression artifacts (regenerated on failure, not canonical)
tests/visual/golden/*_actual.png
tests/visual/golden/*_diff.png
tests/artifacts/

# Local WIP / scratch
configs/_trash/
