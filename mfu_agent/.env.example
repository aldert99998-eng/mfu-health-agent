# LLM (OpenAI-compatible endpoint)
LLM_BASE_URL=http://localhost:8000/v1
LLM_API_KEY=dummy-for-local
LLM_MODEL=qwen2.5-7b-instruct

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333

# App
LOG_LEVEL=INFO
APP_ENV=development

# GigaChat (optional — only if you use the gigachat endpoint)
# The value is a base64(client_id:client_secret) string from your Sber GigaChat account.
# See: https://developers.sber.ru/docs/ru/gigachat/individuals-quickstart
GIGACHAT_AUTH_KEY=
